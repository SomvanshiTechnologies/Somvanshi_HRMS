# Somvanshi HRMS — backend environment (local development)
# Copy to `.env` and fill in. The running `.env` is gitignored.

NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# MySQL 8 (Prisma + MariaDB driver adapter)
DATABASE_URL="mysql://root:root@127.0.0.1:3306/somhr"

# Redis (optional in dev)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Auth secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_32_byte_hex
JWT_REFRESH_SECRET=replace_with_32_byte_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_RESET_TTL_MINUTES=30
ACCOUNT_LOCK_THRESHOLD=5
ACCOUNT_LOCK_MINUTES=15
TWO_FACTOR_ISSUER=SomHR

# Email — driver: smtp (Mailpit on :1025 in dev) | ses (AWS SES in prod)
MAIL_DRIVER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SomHR <no-reply@somvanshitech.com>
SES_REGION=

# Shared AWS config (blank in dev / use instance role on EC2)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Storage: local | s3
STORAGE_DRIVER=local
UPLOAD_DIR=../uploads
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=somhr
S3_KEY_PREFIX=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Sera AI (OpenAI). Leave blank to disable AI features.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
