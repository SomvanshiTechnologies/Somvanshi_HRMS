    "@aws-sdk/client-ses": "^3.1068.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.12",
    "openai": "^6.15.0",
    "otplib": "^12.0.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "prisma": "^7.8.0",
    "rate-limit-redis": "^4.2.3",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5"
