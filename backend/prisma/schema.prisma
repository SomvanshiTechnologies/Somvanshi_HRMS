// =====================================================================
// SomHR — Enterprise HRMS · Somvanshi Technologies
// People. Performance. Growth.
// ---------------------------------------------------------------------
// Complete MySQL 8 data model (Prisma 7).
// Domains: Identity & Access · Organization · Employee · Recruitment ·
// Onboarding · Attendance · Leave · Payroll · Performance · Assets ·
// Helpdesk · Expense · Exit · Notifications · Audit · AI (RAG)
//
// Conventions:
//  - cuid() string PKs, createdAt/updatedAt on every table
//  - Money as Decimal(14,2); soft delete via deletedAt where relevant
//  - companyId on business tables (multi-tenant ready)
//  - MySQL: no scalar lists (Json instead), long text via @db.Text
//  - AI embeddings live in Qdrant (vector DB), keyed by KnowledgeChunk.id
// =====================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =====================================================================
