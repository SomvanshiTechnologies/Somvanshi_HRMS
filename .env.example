# ──────────────────────────────────────────────────────────────────────────────
# Somvanshi HRMS — docker-compose environment
# Copy to `.env` and replace every CHANGE_ME before `docker compose up`.
# NEVER commit the filled-in .env.
# ──────────────────────────────────────────────────────────────────────────────

# --- Database (MySQL 8) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_root
MYSQL_DATABASE=somhr
MYSQL_USER=somhr
MYSQL_PASSWORD=CHANGE_ME_app

# --- App URL (used for CORS, refresh-cookie domain, email links) ---
# In production set to your https domain, e.g. https://hr.somvanshitech.com
APP_URL=http://localhost

# --- JWT secrets (min 16 chars; generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_16_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_16_chars

# --- SMTP (transactional email: welcome, password reset, payslips) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SomHR <no-reply@somvanshitech.com>

# --- File storage: local (default) or s3 ---
STORAGE_DRIVER=local
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Sera AI assistant (OpenAI). Leave blank to disable AI features. ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
