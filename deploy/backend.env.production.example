# Somvanshi HRMS — backend production environment (EC2)
# Copy to backend/.env on the instance and fill in. Better: store this whole file
# in AWS SSM Parameter Store (SecureString) and have the instance fetch it on boot
# (see deploy/PRODUCTION.md → "Secrets"). Generate secrets: openssl rand -hex 32

NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# Public app URL (CloudFront domain). Used for email links + CORS.
# Single-domain CloudFront setup → same origin, so CORS is effectively a no-op,
# but set it correctly anyway. No trailing slash.
CORS_ORIGIN=https://hr.yourdomain.com
APP_URL=https://hr.yourdomain.com

# ── RDS MySQL 8 ──
DATABASE_URL="mysql://admin:CHANGE_ME@somhr.xxxxxx.ap-south-1.rds.amazonaws.com:3306/somhr"

REDIS_ENABLED=false

# ── Auth secrets (REQUIRED — min 16 chars; use 32-byte hex) ──
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
# Field-level PII encryption (PAN/Aadhaar/UAN/ESIC/bank a/c). REQUIRED in prod —
# a dedicated 32-byte key. Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_RESET_TTL_MINUTES=30
ACCOUNT_LOCK_THRESHOLD=5
ACCOUNT_LOCK_MINUTES=15
TWO_FACTOR_ISSUER=SomHR

# ── Email ──
# Driver: ses | resend | smtp.
#  ses    — uses the EC2 instance role (no keys); MAIL_FROM identity must be
#           SES-verified and the account out of the SES sandbox.
#  resend — set RESEND_API_KEY; MAIL_FROM must be a Resend-verified domain
#           (you CANNOT send "from" a gmail.com address via Resend).
MAIL_DRIVER=ses
SES_REGION=ap-south-1
RESEND_API_KEY=
MAIL_FROM=Somvanshi HRMS <no-reply@yourdomain.com>
# Fallback SMTP (used when MAIL_DRIVER=smtp) — Zoho/Gmail app password etc.
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Shared AWS config ──
# On EC2/ECS leave the keys blank to use the instance/task IAM role (recommended).
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── File storage: AWS S3 ──
STORAGE_DRIVER=s3
S3_BUCKET=somhr-uploads
S3_REGION=ap-south-1
S3_KEY_PREFIX=uploads
# S3_ENDPOINT only for S3-compatible stores (MinIO/R2); leave blank for AWS S3.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# UPLOAD_DIR is only used when STORAGE_DRIVER=local
UPLOAD_DIR=../uploads

# ── Sera AI (optional) ──
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
