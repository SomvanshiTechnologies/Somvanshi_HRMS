# Somvanshi HRMS — backend production environment
# Copy to backend/.env on the server and fill in real values.
# Generate secrets with:  openssl rand -hex 32

NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# Public URL of the app (used for CORS + email links). No trailing slash.
CORS_ORIGIN=https://hr.yourdomain.com
APP_URL=https://hr.yourdomain.com

# ── RDS MySQL 8 ──
# mysql://<user>:<password>@<rds-endpoint>:3306/<dbname>
DATABASE_URL="mysql://admin:CHANGE_ME@somhr.xxxxxx.ap-south-1.rds.amazonaws.com:3306/somhr"

# Redis not used yet (add ElastiCache later for distributed rate-limiting)
REDIS_ENABLED=false

# ── Auth secrets (REQUIRED — min 16 chars; use 32-byte hex) ──
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_RESET_TTL_MINUTES=30
ACCOUNT_LOCK_THRESHOLD=5
ACCOUNT_LOCK_MINUTES=15
TWO_FACTOR_ISSUER=SomHR

# ── Email: SKIPPED for now ──
# Leaving these at defaults means reset/notification emails are logged, not sent.
# Configure a real SMTP (Amazon SES / Zoho / Gmail app password) before launch.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Somvanshi HRMS <no-reply@yourdomain.com>

# ── File storage: local disk on the EC2 EBS volume ──
STORAGE_DRIVER=local
UPLOAD_DIR=/home/ubuntu/app/uploads

# ── Sera AI (optional) — fill in to enable JD/resume/assistant features ──
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
